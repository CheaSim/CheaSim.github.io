    <item>
      <title>基于BERT的知识库问答系统</title>
      <link>https://www.cheasim.com/2021/01/14/%E5%9F%BA%E4%BA%8Ebert%E7%9A%84%E7%9F%A5%E8%AF%86%E5%BA%93%E9%97%AE%E7%AD%94%E7%B3%BB%E7%BB%9F/</link>
